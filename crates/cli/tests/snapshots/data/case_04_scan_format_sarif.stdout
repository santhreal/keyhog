{"version":"<S>","$schema":"https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1.0/sarif-schema-2.1.0.json","runs":[{"results":[{"ruleId":"aws-access-key","level":"error","message":{"text":"aws secret detected: AK...YA"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"tree/planted.txt"},"region":{"startLine":1,"charOffset":19}}}],"properties":{"confidence":1.0,"cwe":"CWE-798","metadata.account_id":"052310077262","metadata.canary_message":"AWS canary token (canarytokens.org / Thinkst-style). Do NOT verify: a verification request alerts whoever planted it. See https://trufflesecurity.com/canaries","metadata.is_canary":"true","owasp":"A07:2021","remediation.action":"Disable or delete the exposed IAM access key, then rotate any paired secret access key and session token.","remediation.docs_url":"https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html","remediation.revoke_command":"aws iam update-access-key --access-key-id {{credential}} --status Inactive","remediation.revoke_url":"https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html#Using_ManagingAccessKeys","verification":"skipped"},"relatedLocations":[{"physicalLocation":{"artifactLocation":{"uri":"tree/sub/also.cfg"},"region":{"startLine":2,"charOffset":22}}}],"fixes":[{"description":{"text":"Replace the leaked credential with `${AWS_ACCESS_KEY_ID}` and load `AWS_ACCESS_KEY_ID` from your secret manager."},"artifactChanges":[{"artifactLocation":{"uri":"tree/planted.txt"},"replacements":[{"deletedRegion":{"startLine":1},"insertedContent":{"text":"${AWS_ACCESS_KEY_ID}"}}]}]}],"partialFingerprints":{"keyhog/credentialHash/v1":"01c2c0cfbc4247225dbbe5fdbf59cecb4abdc6a1c6d78b7ff0c7a5b968fb40b2"}}],"tool":{"driver":{"name":"keyhog","version":"<S>","informationUri":"https://github.com/santhsecurity/keyhog","rules":[{"id":"<S>","name":"AWS Access Key","shortDescription":{"text":"aws secret detected"},"fullDescription":{"text":"A aws secret was detected by the AWS Access Key detector"},"help":{"text":"Disable or delete the exposed IAM access key, then rotate any paired secret access key and session token.","markdown":"Disable or delete the exposed IAM access key, then rotate any paired secret access key and session token.\n\nRevoke command:\n\n```sh\naws iam update-access-key --access-key-id {{credential}} --status Inactive\n```\n\nReference: https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html#Using_ManagingAccessKeys"},"helpUri":"https://docs.aws.amazon.com/IAM/latest/UserGuide/id_credentials_access-keys.html#Using_ManagingAccessKeys","properties":{"security-severity":"9.5","service":"aws","severity":"critical","tags":["security"]}}]}},"taxonomies":[{"informationUri":"https://cwe.mitre.org/data/definitions/798.html","name":"CWE","shortDescription":{"text":"Common Weakness Enumeration"},"taxa":[{"helpUri":"https://cwe.mitre.org/data/definitions/798.html","id":"<S>","name":"Use of Hard-coded Credentials","shortDescription":{"text":"The product contains hard-coded credentials, such as a password or cryptographic key, which it uses for its own inbound authentication, outbound communication to external components, or encryption of internal data."}}],"version":"<S>"},{"informationUri":"https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/","name":"OWASP","shortDescription":{"text":"OWASP Top 10:2021"},"taxa":[{"helpUri":"https://owasp.org/Top10/A07_2021-Identification_and_Authentication_Failures/","id":"<S>","name":"Identification and Authentication Failures","shortDescription":{"text":"Confirmation of the user's identity, authentication, and session management is critical to protect against authentication-related attacks."}}],"version":"<S>"}]}]}
