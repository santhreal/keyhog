//! Hand-rolled CUDA driver-API FFI.
//!
//! Loads `libcuda.so` via dlopen so the launcher binary doesn't force-link
//! the CUDA toolchain at compile time. The set of bound symbols is the
//! minimum needed to load PTX, allocate device buffers, copy weights, and
//! launch a persistent kernel.

#![allow(non_snake_case)]
#![allow(non_camel_case_types)]
#![allow(dead_code)]

use std::ffi::{c_char, c_int, c_uint, c_void, CStr, CString};
use std::ptr;
use std::sync::OnceLock;

pub type CUresult = c_int;
pub type CUcontext = *mut c_void;
pub type CUdevice = c_int;
pub type CUmodule = *mut c_void;
pub type CUfunction = *mut c_void;
pub type CUstream = *mut c_void;
pub type CUdeviceptr = u64;

const CUDA_SUCCESS: CUresult = 0;

struct Cuda {
    h_libcuda: *mut c_void,
    cuInit: unsafe extern "C" fn(c_uint) -> CUresult,
    cuDeviceGet: unsafe extern "C" fn(*mut CUdevice, c_int) -> CUresult,
    cuDeviceGetCount: unsafe extern "C" fn(*mut c_int) -> CUresult,
    cuCtxCreate_v2: unsafe extern "C" fn(*mut CUcontext, c_uint, CUdevice) -> CUresult,
    cuCtxDestroy_v2: unsafe extern "C" fn(CUcontext) -> CUresult,
    cuModuleLoadData: unsafe extern "C" fn(*mut CUmodule, *const c_void) -> CUresult,
    cuModuleUnload: unsafe extern "C" fn(CUmodule) -> CUresult,
    cuModuleGetFunction:
        unsafe extern "C" fn(*mut CUfunction, CUmodule, *const c_char) -> CUresult,
    cuMemAlloc_v2: unsafe extern "C" fn(*mut CUdeviceptr, usize) -> CUresult,
    cuMemFree_v2: unsafe extern "C" fn(CUdeviceptr) -> CUresult,
    cuMemcpyHtoD_v2: unsafe extern "C" fn(CUdeviceptr, *const c_void, usize) -> CUresult,
    cuMemcpyDtoH_v2: unsafe extern "C" fn(*mut c_void, CUdeviceptr, usize) -> CUresult,
    cuLaunchKernel: unsafe extern "C" fn(
        CUfunction,
        c_uint,
        c_uint,
        c_uint,
        c_uint,
        c_uint,
        c_uint,
        c_uint,
        CUstream,
        *mut *mut c_void,
        *mut *mut c_void,
    ) -> CUresult,
    cuCtxSynchronize: unsafe extern "C" fn() -> CUresult,
    cuStreamCreate: unsafe extern "C" fn(*mut CUstream, c_uint) -> CUresult,
    cuStreamSynchronize: unsafe extern "C" fn(CUstream) -> CUresult,
}

unsafe impl Send for Cuda {}
unsafe impl Sync for Cuda {}

static CUDA: OnceLock<Cuda> = OnceLock::new();

unsafe fn dlopen(name: &CStr) -> *mut c_void {
    libc::dlopen(name.as_ptr(), libc::RTLD_NOW | libc::RTLD_GLOBAL)
}

unsafe fn dlsym(handle: *mut c_void, sym: &CStr) -> Result<*mut c_void, String> {
    let p = libc::dlsym(handle, sym.as_ptr());
    if p.is_null() {
        let err = libc::dlerror();
        let msg = if err.is_null() {
            "(no dlerror)".to_string()
        } else {
            CStr::from_ptr(err).to_string_lossy().into_owned()
        };
        Err(format!(
            "cuda_ffi: failed to resolve symbol {}: {msg}",
            sym.to_string_lossy()
        ))
    } else {
        Ok(p)
    }
}

fn cuda() -> Result<&'static Cuda, String> {
    if let Some(c) = CUDA.get() {
        return Ok(c);
    }
    let c = unsafe {
        let names: [&CStr; 2] = [
            CStr::from_bytes_with_nul(b"libcuda.so.1\0").unwrap(),
            CStr::from_bytes_with_nul(b"libcuda.so\0").unwrap(),
        ];
        let mut h: *mut c_void = ptr::null_mut();
        for n in names {
            h = dlopen(n);
            if !h.is_null() {
                break;
            }
        }
        if h.is_null() {
            return Err("cuda_ffi: libcuda.so not found. Fix: install NVIDIA driver runtime.".to_string());
        }

        macro_rules! sym {
            ($name:literal) => {{
                let s = CString::new($name).unwrap();
                std::mem::transmute(dlsym(h, &s)?)
            }};
        }

        Cuda {
            h_libcuda: h,
            cuInit: sym!("cuInit"),
            cuDeviceGet: sym!("cuDeviceGet"),
            cuDeviceGetCount: sym!("cuDeviceGetCount"),
            cuCtxCreate_v2: sym!("cuCtxCreate_v2"),
            cuCtxDestroy_v2: sym!("cuCtxDestroy_v2"),
            cuModuleLoadData: sym!("cuModuleLoadData"),
            cuModuleUnload: sym!("cuModuleUnload"),
            cuModuleGetFunction: sym!("cuModuleGetFunction"),
            cuMemAlloc_v2: sym!("cuMemAlloc_v2"),
            cuMemFree_v2: sym!("cuMemFree_v2"),
            cuMemcpyHtoD_v2: sym!("cuMemcpyHtoD_v2"),
            cuMemcpyDtoH_v2: sym!("cuMemcpyDtoH_v2"),
            cuLaunchKernel: sym!("cuLaunchKernel"),
            cuCtxSynchronize: sym!("cuCtxSynchronize"),
            cuStreamCreate: sym!("cuStreamCreate"),
            cuStreamSynchronize: sym!("cuStreamSynchronize"),
        }
    };
    if CUDA.set(c).is_err() {
        return CUDA
            .get()
            .ok_or_else(|| "CUDA driver table was initialized concurrently but is unavailable".to_string());
    }
    CUDA.get()
        .ok_or_else(|| "CUDA driver table initialized but unavailable".to_string())
}

fn check(rc: CUresult, op: &str) -> Result<(), String> {
    if rc == CUDA_SUCCESS {
        Ok(())
    } else {
        Err(format!("cuda_ffi: {op} returned CUresult {rc}"))
    }
}

pub fn cu_init() -> Result<(), String> {
    let c = cuda()?;
    unsafe { check((c.cuInit)(0), "cuInit") }
}

pub fn cu_device_get(ordinal: c_int) -> Result<CUdevice, String> {
    let c = cuda()?;
    let mut dev: CUdevice = 0;
    unsafe {
        check((c.cuDeviceGet)(&mut dev, ordinal), "cuDeviceGet")?;
    }
    Ok(dev)
}

pub fn cu_device_count() -> Result<i32, String> {
    let c = cuda()?;
    let mut n: c_int = 0;
    unsafe {
        check((c.cuDeviceGetCount)(&mut n), "cuDeviceGetCount")?;
    }
    Ok(n as i32)
}

pub struct CtxGuard {
    raw: CUcontext,
}

impl Drop for CtxGuard {
    fn drop(&mut self) {
        if let Ok(c) = cuda() {
            unsafe {
                let rc = (c.cuCtxDestroy_v2)(self.raw);
                if rc != CUDA_SUCCESS {
                    eprintln!("CUDA context destroy failed with code {rc}");
                }
            }
        }
    }
}

pub fn cu_ctx_create(device: CUdevice) -> Result<CtxGuard, String> {
    let c = cuda()?;
    let mut ctx: CUcontext = ptr::null_mut();
    unsafe {
        check(
            (c.cuCtxCreate_v2)(&mut ctx, 0, device),
            "cuCtxCreate_v2",
        )?;
    }
    Ok(CtxGuard { raw: ctx })
}

pub fn cu_module_load_data(bytes: &[u8]) -> Result<CUmodule, String> {
    let c = cuda()?;
    // PTX must be NUL-terminated for cuModuleLoadData.
    let mut buf = bytes.to_vec();
    if !buf.ends_with(&[0]) {
        buf.push(0);
    }
    let mut m: CUmodule = ptr::null_mut();
    unsafe {
        check(
            (c.cuModuleLoadData)(&mut m, buf.as_ptr() as *const c_void),
            "cuModuleLoadData",
        )?;
    }
    Ok(m)
}

pub fn cu_module_get_function(module: CUmodule, name: &str) -> Result<CUfunction, String> {
    let c = cuda()?;
    let cname = CString::new(name).map_err(|e| format!("name has nul: {e}"))?;
    let mut f: CUfunction = ptr::null_mut();
    unsafe {
        check(
            (c.cuModuleGetFunction)(&mut f, module, cname.as_ptr()),
            "cuModuleGetFunction",
        )?;
    }
    Ok(f)
}

pub fn cu_mem_alloc(bytes: u64) -> Result<CUdeviceptr, String> {
    let c = cuda()?;
    let mut dptr: CUdeviceptr = 0;
    unsafe {
        check(
            (c.cuMemAlloc_v2)(&mut dptr, bytes as usize),
            "cuMemAlloc_v2",
        )?;
    }
    Ok(dptr)
}

pub fn cu_mem_free(dptr: CUdeviceptr) -> Result<(), String> {
    let c = cuda()?;
    unsafe { check((c.cuMemFree_v2)(dptr), "cuMemFree_v2") }
}

pub fn cu_memcpy_h_to_d(dst: CUdeviceptr, src: &[u8]) -> Result<(), String> {
    let c = cuda()?;
    unsafe {
        check(
            (c.cuMemcpyHtoD_v2)(dst, src.as_ptr() as *const c_void, src.len()),
            "cuMemcpyHtoD_v2",
        )
    }
}

pub fn cu_memcpy_d_to_h(dst: &mut [u32], src: CUdeviceptr) -> Result<(), String> {
    let c = cuda()?;
    let bytes = std::mem::size_of_val(dst);
    unsafe {
        check(
            (c.cuMemcpyDtoH_v2)(dst.as_mut_ptr() as *mut c_void, src, bytes),
            "cuMemcpyDtoH_v2",
        )
    }
}

pub fn cu_memcpy_d_to_h_offset(
    dst: &mut [u32],
    src: CUdeviceptr,
    offset_bytes: u64,
) -> Result<(), String> {
    let c = cuda()?;
    let bytes = std::mem::size_of_val(dst);
    unsafe {
        check(
            (c.cuMemcpyDtoH_v2)(dst.as_mut_ptr() as *mut c_void, src + offset_bytes, bytes),
            "cuMemcpyDtoH_v2 (offset)",
        )
    }
}

pub fn cu_launch_kernel(
    f: CUfunction,
    grid: [u32; 3],
    block: [u32; 3],
    shared_bytes: u32,
    device_ptrs: &[u64],
) -> Result<(), String> {
    let c = cuda()?;
    // Grid of zero indicates "default 1x1x1" — we pick the launcher-side
    // default unless the manifest provides a non-zero grid.
    let gx = if grid[0] == 0 { 1 } else { grid[0] };
    let gy = if grid[1] == 0 { 1 } else { grid[1] };
    let gz = if grid[2] == 0 { 1 } else { grid[2] };

    // Build kernel arguments: a vector of *mut *mut c_void pointing at each device pointer.
    let mut arg_storage: Vec<u64> = device_ptrs.to_vec();
    let mut arg_ptrs: Vec<*mut c_void> = arg_storage
        .iter_mut()
        .map(|p| p as *mut u64 as *mut c_void)
        .collect();

    unsafe {
        check(
            (c.cuLaunchKernel)(
                f,
                gx,
                gy,
                gz,
                block[0],
                block[1],
                block[2],
                shared_bytes,
                ptr::null_mut(),
                arg_ptrs.as_mut_ptr(),
                ptr::null_mut(),
            ),
            "cuLaunchKernel",
        )
    }
}

pub fn cu_stream_synchronize() -> Result<(), String> {
    let c = cuda()?;
    // Use cuCtxSynchronize as a coarse default-stream barrier.
    unsafe { check((c.cuCtxSynchronize)(), "cuCtxSynchronize") }
}
