# glibc (Debian) integration image for the Docker test matrix.
#
# Builds the Hyperscan-accelerated keyhog (`--features ci-lean`: full
# ML/entropy/decode/multiline/simdsieve + Hyperscan SIMD, GPU stack OFF) and
# bakes in a small corpus under /data/corpus so the scenario runner can drive
# the real binary under spoofed hardware/env.
#
# Feature set: `--no-default-features --features ci-lean`, NOT default. The cli
# `default` pulls `keyhog-scanner/default`, which includes `gpu` = wgpu + the
# 26-crate vyre graph + cuda + naga. Compiling that closure on the 2-vCPU
# `ubuntu-latest` runner took >45 min and was CANCELLED at the job timeout
# EVERY run (run 26865967197: glibc ran the full 45 min then died; musl
# finished in 11) - i.e. the glibc leg never validated anything. `ci-lean` is
# the exact feature set `ci.yml`'s integration-tests job already builds, so the
# two stay coherent. This leg's UNIQUE value vs the musl leg is the **Hyperscan**
# path (a C lib that links on glibc, not musl) - `ci-lean` keeps `simd`, so that
# is still exercised. The scenario battery (scan/doctor/format/`--no-gpu`/
# `--require-gpu` fail-closed) is GPU-less by construction - it ALREADY
# passes on the musl `--features portable` (no-GPU) image, proving none of it
# needs the GPU feature compiled in. GPU build validation belongs to the
# release-build + runners-nightly (real-GPU) workflows, not a wall-clock-bounded
# CPU-runner scenario matrix.
#
# Build profile: `release-fast` (thin LTO, codegen-units=16, debug-assertions
# ON), NOT `release`. Runtime scenario behaviour is identical across LTO modes,
# and the extra debug-assertions match the rest of CI's test profile; fat-LTO
# shipping-binary validation belongs to the release-build workflow.
#
# Pin the builder to bookworm so its glibc matches the bookworm runtime
# stage below. Plain `rust:1.89-slim` tracks Debian testing (trixie, glibc
# 2.39+) and produces a binary that won't load on bookworm (glibc 2.36).
FROM rust:1.89-slim-bookworm AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
        libhyperscan-dev pkg-config ca-certificates libssl-dev \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --profile release-fast -p keyhog --no-default-features --features ci-lean

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates git libhyperscan5 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release-fast/keyhog /usr/local/bin/keyhog
COPY --from=builder /build/detectors /usr/share/keyhog/detectors
# Bake the scan corpus at /data/corpus, a NEUTRAL path with no `test`/`tests`/
# `fixtures`/`spec`/`testdata` component (see crates/scanner/data/test-path-rules.toml).
# Under `--precision` keyhog's test-path heuristic penalises credentials sitting in
# a `/test/...` path (treating them as fixtures), dropping the planted AWS key below
# the 0.85 high-precision floor, which would break scenarios.sh's invariant that the
# key is found under EVERY profile. A `/data/...` path is not penalised, so the
# invariant holds for `--precision` too; the calibration bake below covers each
# profile's resolved config digest at these exact paths.
COPY tests/docker/corpus /data/corpus
# Non-root, mirroring the production image: scans of mounted volumes must
# not require root.
RUN useradd --system --create-home --uid 1000 keyhog
USER keyhog
WORKDIR /data

# Bake the autoroute calibration into the image. The ci-lean build has BOTH the
# Hyperscan/SIMD backend and the scalar CPU backend, so an auto scan must choose
# between them, and a missing decision fails closed (exit 2), which is exactly
# what every auto-backend scenario hit before this step. Autoroute keys a decision
# on (resolved config digest × workload bucket); scenarios.sh exercises SEVERAL of
# each, so this bake must cover EVERY auto-backend (workload, config) pair the
# matrix runs, or that scenario fail-closes. The coverage, mirroring scenarios.sh:
#   - policy profiles × the 3 corpus files: the Layer-1 invariance grid
#     ("" --fast --deep --precision --no-entropy --no-ml --no-gpu --threads 1).
#   - the corpus DIRECTORY  (surf:scan-dir): a different workload bucket than a file.
#   - --min-confidence 0.0  (surf:scan-min-confidence): a distinct config digest.
#   - --threads 64          (surf:scan-threads-64): a distinct config digest.
#   - stdin fed aws_leak.env (special:stdin-scan): the stdin source class + this
#     exact byte stream; scenarios.sh pipes the SAME file so the bucket matches.
# Explicit `--backend cpu|simd` scenarios bypass autoroute (no decision needed);
# --require-gpu fails closed on GPU-absence (exit 12, cache-independent); an empty
# dir (scan /tmp) has zero files and routes to exit 0 without a decision. If a NEW
# matrix scenario introduces an uncalibrated (workload, config) pair, run.sh sees a
# LOUD exit 2 against the built image (drift fails the test, never ships silent).
# Decisions accumulate in the current multi-config cache at ~/.cache/keyhog/autoroute.json,
# baked into this layer and read by every later `docker run --rm`.
# NOTE on exit codes: `--autoroute-calibrate` is a routing-measurement command,
# so successful calibration returns 0 even when the measured scan finds a
# credential. Any non-zero result is a calibration failure and aborts the image
# build (Law 10: never ship a silently uncalibrated image).
RUN calib() { \
        keyhog scan --autoroute-calibrate --autoroute-gpu "$@" --format json >/dev/null; \
        rc=$?; \
        if [ "$rc" != 0 ]; then \
            echo "autoroute calibration failed (exit $rc): keyhog scan --autoroute-calibrate --autoroute-gpu $*" >&2; \
            exit 1; \
        fi; \
    }; \
    for prof in "" "--fast" "--deep" "--precision" "--no-entropy" "--no-ml" "--no-gpu" "--threads 1"; do \
        for f in aws_leak.env clean.txt fp_trap.txt; do calib "/data/corpus/$f" $prof; done; \
    done; \
    calib /data/corpus; \
    calib /data/corpus/aws_leak.env --min-confidence 0.0; \
    calib /data/corpus/aws_leak.env --threads 64; \
    calib --stdin < /data/corpus/aws_leak.env

ENTRYPOINT []
