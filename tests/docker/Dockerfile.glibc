# glibc (Debian) integration image for the Docker test matrix.
#
# Builds the Hyperscan-accelerated keyhog (`--features ci-lean`: full
# ML/entropy/decode/multiline/simdsieve + Hyperscan SIMD, GPU stack OFF) and
# bakes in a small corpus under /test/corpus so the scenario runner can drive
# the real binary under spoofed hardware/env.
#
# Feature set: `--no-default-features --features ci-lean`, NOT default. The cli
# `default` pulls `keyhog-scanner/default`, which includes `gpu` = wgpu + the
# 26-crate vyre graph + cuda + naga. Compiling that closure on the 2-vCPU
# `ubuntu-latest` runner took >45 min and was CANCELLED at the job timeout
# EVERY run (run 26865967197: glibc ran the full 45 min then died; musl
# finished in 11) - i.e. the glibc leg never validated anything. `ci-lean` is
# the exact feature set `ci.yml`'s integration-tests job already builds, so the
# two stay coherent. This leg's UNIQUE value vs the musl leg is the **Hyperscan**
# path (a C lib that links on glibc, not musl) - `ci-lean` keeps `simd`, so that
# is still exercised. The scenario battery (scan/doctor/format/`--no-gpu`/
# `--require-gpu` fail-closed) is GPU-less by construction - it ALREADY
# passes on the musl `--features portable` (no-GPU) image, proving none of it
# needs the GPU feature compiled in. GPU build validation belongs to the
# release-build + runners-nightly (real-GPU) workflows, not a wall-clock-bounded
# CPU-runner scenario matrix.
#
# Build profile: `release-fast` (thin LTO, codegen-units=16, debug-assertions
# ON), NOT `release`. Runtime scenario behaviour is identical across LTO modes,
# and the extra debug-assertions match the rest of CI's test profile; fat-LTO
# shipping-binary validation belongs to the release-build workflow.
#
# Pin the builder to bookworm so its glibc matches the bookworm runtime
# stage below. Plain `rust:1.89-slim` tracks Debian testing (trixie, glibc
# 2.39+) and produces a binary that won't load on bookworm (glibc 2.36).
FROM rust:1.89-slim-bookworm AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y --no-install-recommends \
        libhyperscan-dev pkg-config ca-certificates libssl-dev \
    && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --profile release-fast -p keyhog --no-default-features --features ci-lean

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates git libhyperscan5 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release-fast/keyhog /usr/local/bin/keyhog
COPY --from=builder /build/detectors /usr/share/keyhog/detectors
COPY tests/docker/corpus /test/corpus
# Non-root, mirroring the production image: scans of mounted volumes must
# not require root.
RUN useradd --system --create-home --uid 1000 keyhog
USER keyhog
WORKDIR /test
ENTRYPOINT []
